{
  "name": "쿠팡 검색결과 애드온",
  "version": "1.15.6",
  "manifest_version": 3,
  "permissions": ["scripting", "storage", "tabs"],
  "host_permissions": ["https://www.coupang.com/*", "https://cart.coupang.com/*", "https://mc.coupang.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.coupang.com/*", "https://cart.coupang.com/*", "https://mc.coupang.com/*"],
      "js": ["preset-data.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
