{
  "name": "알뜰이",
  "short_name": "알뜰이",
  "description": "쿠팡 검색·관련 페이지의 정렬·필터·표시 항목 조정을 돕는 비공식 보조 도구입니다.",
  "version": "1.16.3",
  "manifest_version": 3,
  "permissions": ["scripting", "storage", "tabs"],
  "host_permissions": ["https://www.coupang.com/*", "https://cart.coupang.com/*", "https://mc.coupang.com/*", "https://altteuri.vercel.app/*"],
  "content_scripts": [
    {
      "matches": ["https://www.coupang.com/*", "https://cart.coupang.com/*", "https://mc.coupang.com/*"],
      "js": ["preset-data.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "알뜰이",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
